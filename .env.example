# Preferred single Prisma connection string.
# If DB_USER or DB_PASSWORD contains special characters (@ # ! : / ? &),
# URL-encode them when you set DATABASE_URL manually.
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME"

# Optional split variables. If DATABASE_URL is empty, the app and Prisma config build it from these.
# For Hostinger Node.js Web App, use your MySQL server host (example: srv1983.hstgr.io), not localhost.
DB_HOST="srv1983.hstgr.io"
DB_PORT="3306"
DB_NAME="replace-with-database-name"
DB_USER="replace-with-database-user"
DB_PASSWORD="replace-with-database-password"

NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
SITE_URL="https://your-domain.com"

ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="replace-with-a-strong-password"

COMPANY_PHONE="replace-with-company-phone"
ZALO_URL="https://zalo.me/replace-with-zalo-phone"
