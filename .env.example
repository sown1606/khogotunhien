# Preferred single Prisma connection string.
# If DB_USER or DB_PASSWORD contains special characters (@ # ! : / ? &),
# URL-encode them when you set DATABASE_URL manually.
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME"

# Optional split variables. If DATABASE_URL is empty, the app and Prisma config build it from these.
# Mode A (Hostinger app runtime): DB_HOST can be "localhost".
# Mode B (external/local machine): DB_HOST can be Hostinger Remote MySQL hostname/IP (example: srv1983.hstgr.io).
DB_HOST="srv1983.hstgr.io"
DB_PORT="3306"
DB_NAME="replace-with-database-name"
DB_USER="replace-with-database-user"
DB_PASSWORD="replace-with-database-password"

NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# Use full URL with protocol. Example: https://khogotunhien.com
SITE_URL="https://your-domain.com"

ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="replace-with-a-strong-password"

COMPANY_PHONE="replace-with-company-phone"
ZALO_URL="https://zalo.me/replace-with-zalo-phone"

# Optional safeguard for production seeding.
ALLOW_PRODUCTION_SEED="false"

# Optional runtime fallback for storefront demo catalog.
# Keep "true" if you want public pages to stay populated when DB is empty/unavailable.
DEMO_CATALOG_FALLBACK="true"

# Optional AI copy assistant in admin visual editor.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
