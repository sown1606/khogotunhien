generator client {
  provider = "prisma-client-js"
  engineType = "binary"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  EDITOR
}

enum HomepageSectionType {
  FEATURED_PRODUCTS
  FEATURED_CATEGORIES
  CURATED_COLLECTION
  PROMOTIONAL
  CUSTOM
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Category {
  id               String                @id @default(cuid())
  name             String
  nameEn           String?
  slug             String                @unique
  imageUrl         String?
  shortDescription String?
  shortDescriptionEn String?
  featured         Boolean               @default(false)
  active           Boolean               @default(true)
  sortOrder        Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  products         Product[]
  homepageItems    HomepageSectionItem[]

  @@index([active, sortOrder])
  @@index([featured, sortOrder])
}

model Product {
  id               String                @id @default(cuid())
  name             String
  nameEn           String?
  slug             String                @unique
  shortDescription String?
  shortDescriptionEn String?
  description      String?               @db.Text
  descriptionEn    String?               @db.Text
  thumbnailUrl     String?
  woodType         String?
  woodTypeEn       String?
  material         String?
  materialEn       String?
  dimensions       String?
  dimensionsEn     String?
  finish           String?
  finishEn         String?
  featured         Boolean               @default(false)
  active           Boolean               @default(true)
  sortOrder        Int                   @default(0)
  categoryId       String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  category         Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images           ProductImage[]
  homepageItems    HomepageSectionItem[]
  relatedProducts  Product[]             @relation("RelatedProducts")
  relatedTo        Product[]             @relation("RelatedProducts")

  @@index([active, sortOrder])
  @@index([featured, sortOrder])
  @@index([categoryId, active, sortOrder])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model HomepageSection {
  id          String              @id @default(cuid())
  title       String
  titleEn     String?
  slug        String              @unique
  description String?
  descriptionEn String?
  type        HomepageSectionType @default(CUSTOM)
  visible     Boolean             @default(true)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  items       HomepageSectionItem[]

  @@index([visible, sortOrder])
}

model HomepageSectionItem {
  id                String          @id @default(cuid())
  sectionId         String
  productId         String?
  categoryId        String?
  customTitle       String?
  customTitleEn     String?
  customDescription String?
  customDescriptionEn String?
  imageUrl          String?
  linkUrl           String?
  active            Boolean         @default(true)
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  section           HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product           Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  category          Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([sectionId, sortOrder])
  @@index([productId])
  @@index([categoryId])
}

model SiteSetting {
  id                  String   @id @default("default")
  companyName         String
  companyDescription  String?  @db.Text
  companyDescriptionEn String? @db.Text
  address             String?
  addressEn           String?
  phoneNumber         String?
  email               String?
  zaloLink            String?
  facebookLink        String?
  tiktokLink          String?
  logoUrl             String?
  faviconUrl          String?
  seoTitle            String?
  seoTitleEn          String?
  seoDescription      String?
  seoDescriptionEn    String?
  seoKeywords         String?
  footerContent       String?  @db.Text
  footerContentEn     String?  @db.Text
  openingHours        String?
  openingHoursEn      String?
  contactPrimaryLabel String   @default("Contact via Zalo")
  contactPrimaryLabelEn String?
  contactSecondaryLabel String @default("Call now")
  contactSecondaryLabelEn String?
  leadPopupEnabled    Boolean  @default(true)
  leadPopupDelaySeconds Int    @default(25)
  leadPopupTitle      String?  @default("Cần hỗ trợ nhanh?")
  leadPopupTitleEn    String?
  leadPopupDescription String? @db.Text
  leadPopupDescriptionEn String? @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LeadCapture {
  id         String   @id @default(cuid())
  name       String?
  email      String?
  phone      String?
  message    String?  @db.Text
  sourcePath String?
  locale     String?  @default("vi")
  status     String   @default("NEW")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model VisitLog {
  id         String   @id @default(cuid())
  path       String
  locale     String?  @default("vi")
  referrer   String?
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([path, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}
